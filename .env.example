# ============================================
# MySQL
# ============================================

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=themoa_policy_search
MYSQL_USERNAME=themoa
MYSQL_PASSWORD=themoa_password
MYSQL_ROOT_PASSWORD=root_password


# ============================================
# Qdrant
# ============================================

QDRANT_HOST=localhost
QDRANT_REST_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=policies
QDRANT_AUTO_CREATE_COLLECTION=true


# ============================================
# Spring Boot
# ============================================

SERVER_PORT=8080

# 로컬 관리자 API 호출용 키
ADMIN_API_KEY=themoa-local-admin-key


# ============================================
# RAG / OpenAI
# ============================================

# OpenAI API 키를 아직 입력하지 않으므로 비활성화
RAG_ENABLED=false

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_BATCH_SIZE=100
RAG_EMBEDDING_MAX_BATCHES_PER_RUN=1000
RAG_EMBEDDING_REQUEST_DELAY=50ms
RAG_SEARCH_TOP_K=50
RAG_SEARCH_RETRY_TOP_K=150
RAG_MINIMUM_SIMILARITY=0.50


# ============================================
# 정책 외부 API
# ============================================

# 실제 발급 키는 사용자가 나중에 직접 입력
YOUTH_CENTER_API_KEY=
GOV_SERVICE_BASE_URL=https://api.odcloud.kr/api
GOV_SERVICE_LIST_PATH=/gov24/v3/serviceList
GOV_SERVICE_DETAIL_PATH=/gov24/v3/serviceDetail
GOV_SERVICE_SUPPORT_CONDITIONS_PATH=/gov24/v3/supportConditions
GOV_SERVICE_API_KEY=
LOCAL_WELFARE_BASE_URL=https://apis.data.go.kr/B554287/LocalGovernmentWelfareInformations
LOCAL_WELFARE_LIST_PATH=/LcgvWelfarelist
LOCAL_WELFARE_DETAIL_PATH=/LcgvWelfaredetailed
LOCAL_WELFARE_API_KEY=
CENTRAL_WELFARE_BASE_URL=https://apis.data.go.kr/B554287/NationalWelfareInformationsV001
CENTRAL_WELFARE_LIST_PATH=/NationalWelfarelistV001
CENTRAL_WELFARE_DETAIL_PATH=/NationalWelfaredetailedV001
CENTRAL_WELFARE_API_KEY=


# ============================================
# 정책 수집 설정
# ============================================

# API 키가 없으므로 자동 수집 비활성화
POLICY_COLLECTION_ENABLED=false

POLICY_COLLECTION_CRON=0 0 3 * * *
POLICY_COLLECTION_PAGE_SIZE=100
POLICY_COLLECTION_MAX_PAGES=1000
POLICY_COLLECTION_REQUEST_DELAY=500ms
POLICY_DETAIL_REQUEST_DELAY=100ms
POLICY_DETAIL_MAX_CONCURRENCY=3
POLICY_COLLECTION_MAX_RETRIES=3
POLICY_COLLECTION_CONNECT_TIMEOUT=3s
POLICY_COLLECTION_READ_TIMEOUT=10s
YOUTH_CENTER_COLLECTION_ENABLED=false
GOV_SERVICE_COLLECTION_ENABLED=true
LOCAL_WELFARE_COLLECTION_ENABLED=true
CENTRAL_WELFARE_COLLECTION_ENABLED=true
